      "cardCodeSource": "<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Responsive Slide Timer</title>\n  <style>\n    :root {\n      --bg: #0a0a0a;\n      --accent: #e50914; /* Netflix Red */\n      --text: #ffffff;\n    }\n\n    body, html {\n      margin: 0;\n      padding: 0;\n      height: 100%;\n      width: 100%;\n      background: var(--bg);\n      color: var(--text);\n      font-family: 'Inter', -apple-system, sans-serif;\n      overflow: hidden;\n      display: flex;\n      justify-content: center;\n      align-items: center;\n      user-select: none;\n    }\n\n    /* The Responsive Container */\n    .app-viewport {\n      display: flex;\n      flex-direction: column;\n      justify-content: center;\n      align-items: center;\n      width: 90vw;\n      height: 90vh;\n      text-align: center;\n      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n    }\n\n    /* Scaling Typography based on Viewport Width */\n    .time-val {\n      font-size: clamp(4rem, 20vw, 15rem);\n      font-weight: 900;\n      margin: 0;\n      line-height: 0.9;\n      cursor: ew-resize;\n      font-variant-numeric: tabular-nums;\n      letter-spacing: -0.05em;\n      transition: transform 0.2s ease, color 0.3s ease;\n    }\n\n    /* \"Netflix\" Hover/Click Effect */\n    .time-val:active {\n      transform: scale(1.05);\n      color: var(--accent);\n    }\n\n    .label {\n      font-size: clamp(0.8rem, 2vw, 1.5rem);\n      text-transform: uppercase;\n      letter-spacing: 0.3em;\n      opacity: 0.5;\n      margin-bottom: 2vh;\n    }\n\n    .controls {\n      margin-top: 5vh;\n      width: 100%;\n    }\n\n    button {\n      background: var(--text);\n      border: none;\n      color: var(--bg);\n      padding: 1.5vh 4vw;\n      font-size: clamp(1rem, 1.5vw, 2rem);\n      font-weight: 800;\n      border-radius: 4px;\n      cursor: pointer;\n      transition: all 0.2s ease;\n      text-transform: uppercase;\n    }\n\n    button:hover {\n      transform: scale(1.1);\n      background: var(--accent);\n      color: white;\n    }\n\n    button:active {\n      transform: scale(0.95);\n    }\n\n    .hint {\n      position: fixed;\n      bottom: 3vh;\n      font-size: clamp(0.6rem, 1vw, 1rem);\n      opacity: 0.3;\n      width: 100%;\n      text-align: center;\n    }\n  </style>\n</head>\n<body>\n\n<div class=\"app-viewport\" id=\"app\">\n  <div class=\"label\" id=\"status\">Slide to set</div>\n  <h1 class=\"time-val\" id=\"display\">25:00</h1>\n  \n  <div class=\"controls\">\n    <button id=\"start-btn\">Start</button>\n  </div>\n</div>\n\n<div class=\"hint\">Click & Drag Time • Responsive Viewport</div>\n\n<script>\n  let seconds = 1500;\n  let isRunning = false;\n  let timerInterval = null;\n  let isDragging = false;\n  let startX = 0;\n  let startSeconds = 0;\n\n  const display = document.getElementById('display');\n  const startBtn = document.getElementById('start-btn');\n  const status = document.getElementById('status');\n\n  function updateUI() {\n    const mins = Math.floor(seconds / 60);\n    const secs = seconds % 60;\n    display.textContent = `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;\n  }\n\n  // --- Drag & Scale Interaction ---\n  const startDrag = (e) => {\n    if (isRunning) return;\n    isDragging = true;\n    startX = e.pageX || e.touches[0].pageX;\n    startSeconds = seconds;\n  };\n\n  const onDrag = (e) => {\n    if (!isDragging) return;\n    const currentX = e.pageX || (e.touches ? e.touches[0].pageX : 0);\n    const diff = currentX - startX;\n    \n    // Adjusted sensitivity for large screens\n    const sensitivity = window.innerWidth / 100; \n    const minuteChange = Math.floor(diff / sensitivity); \n    \n    let newSeconds = startSeconds + (minuteChange * 60);\n    if (newSeconds < 60) newSeconds = 60;\n    if (newSeconds > 5940) newSeconds = 5940;\n    \n    seconds = newSeconds;\n    updateUI();\n  };\n\n  const endDrag = () => { isDragging = false; };\n\n  // --- Logic ---\n  startBtn.onclick = () => {\n    if (isRunning) {\n      clearInterval(timerInterval);\n      startBtn.textContent = 'Start';\n      status.textContent = 'Paused';\n    } else {\n      status.textContent = 'Counting...';\n      startBtn.textContent = 'Stop';\n      timerInterval = setInterval(() => {\n        seconds--;\n        updateUI();\n        if (seconds <= 0) {\n          clearInterval(timerInterval);\n          alert(\"Time's up!\");\n          resetTimer();\n        }\n      }, 1000);\n    }\n    isRunning = !isRunning;\n  };\n\n  function resetTimer() {\n    isRunning = false;\n    startBtn.textContent = 'Start';\n    status.textContent = 'Slide to set';\n    updateUI();\n  }\n\n  // Mouse & Touch Bindings\n  display.addEventListener('mousedown', startDrag);\n  window.addEventListener('mousemove', onDrag);\n  window.addEventListener('mouseup', endDrag);\n  \n  display.addEventListener('touchstart', startDrag);\n  window.addEventListener('touchmove', onDrag);\n  window.addEventListener('touchend', endDrag);\n\n  updateUI();\n</script>\n\n</body>\n</html>",
